# ── Docker Compose Environment ──────────────────────────────
# Copy to .env and fill with real values before: docker compose up -d

# Database
DB_NAME=analitics
DB_USER=analitics
DB_PASSWORD=change-me-to-strong-password

# JWT
JWT_SECRET=change-me-to-min-32-char-random-string
JWT_EXPIRES_IN=7d

# Web
WEB_PORT=8082
FRONTEND_URL=http://localhost:8082

# Microsoft 365 (optional — leave empty if not using OneDrive sync)
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
MS_REDIRECT_URI=
MS_TOKEN_ENCRYPTION_KEY=
